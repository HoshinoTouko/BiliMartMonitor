# Copy this file to `.env` and fill in secrets locally.
# Never commit real tokens, cookies, passwords, or generated config files.

# Database backend
BSM_DB_BACKEND=sqlite
BSM_SQLITE_PATH=./data/scan.db
BSM_SQLITE_TEST_PATH=./data/test_scan.db

# Cloudflare D1 (used when BSM_DB_BACKEND=cloudflare)
BSM_CF_ACCOUNT_ID=
BSM_CF_DATABASE_ID=
BSM_CF_API_TOKEN=
BSM_CF_TIMEOUT=15

# Session signing secret (required in production)
BSM_SESSION_SECRET=
